---
import type { Post } from '../lib/posts';
import { computeReadTime } from '../lib/readTime';

interface Props {
  posts: Post[];
  /** "compact" = title-only rows (blog index); "detailed" = title + description + meta (tag/category pages) */
  variant?: 'compact' | 'detailed';
  /** group rows under sticky year labels (blog index) */
  groupByYear?: boolean;
}

const { posts, variant = 'compact', groupByYear = false } = Astro.props;

const dateOpts =
  variant === 'detailed'
    ? ({ year: 'numeric', month: 'long', day: 'numeric' } as const)
    : ({ year: 'numeric', month: 'short', day: 'numeric' } as const);

function metaFor(post: Post) {
  return {
    date: post.data.date.toLocaleDateString('en-US', dateOpts),
    readTime: computeReadTime(post.body, post.data.readTime),
  };
}

// Build year buckets only when grouping.
const byYear: [string, Post[]][] = [];
if (groupByYear) {
  const map: Record<string, Post[]> = {};
  for (const post of posts) {
    const year = post.data.date.getFullYear().toString();
    (map[year] ??= []).push(post);
  }
  for (const year of Object.keys(map).sort((a, b) => Number(b) - Number(a))) {
    byYear.push([year, map[year]]);
  }
}
---

{groupByYear ? (
  <div class="flex flex-col gap-8 md:gap-10">
    {byYear.map(([year, yearPosts]) => (
      <div class="flex flex-col md:flex-row md:gap-10">
        {/* Year label - mobile */}
        <div class="flex items-center gap-3 mb-1 md:hidden" aria-hidden="true">
          <span class="text-xs font-mono font-semibold text-muted-foreground uppercase tracking-wider shrink-0">{year}</span>
          <div class="flex-1 h-px bg-border/40"></div>
        </div>
        {/* Year label - desktop */}
        <div class="hidden md:flex w-14 shrink-0 flex-col items-end pt-[1.1rem]">
          <span class="text-xs font-mono font-semibold text-muted-foreground uppercase tracking-wider sticky top-24">{year}</span>
        </div>
        {/* Posts */}
        <div class="flex-1 md:border-t md:border-border/30 pt-1">
          <ul class="flex flex-col divide-y divide-border/20">
            {yearPosts.map((post) => (
              <li>
                <a href={`/blog/${post.slug}`} class="blog-card-link block w-full py-3 -mx-4 px-4 transition-colors duration-300 rounded">
                  <h3 class="blog-card-title font-mono text-sm font-semibold leading-snug text-foreground/90 transition-colors duration-150">
                    {post.data.title}
                  </h3>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    ))}
  </div>
) : (
  <ul class="flex flex-col divide-y divide-border/20">
    {posts.map((post) => {
      const meta = metaFor(post);
      return (
        <li>
          <a href={`/blog/${post.slug}`} class="blog-card-link block w-full py-4 -mx-4 px-4 transition-colors duration-300 rounded">
            <div class="flex flex-col gap-1.5">
              <h2 class="blog-card-title font-mono text-base font-semibold leading-snug text-foreground/90 transition-colors duration-150">
                {post.data.title}
              </h2>
              {variant === 'detailed' && post.data.description && (
                <p class="font-mono text-sm leading-relaxed text-muted-foreground line-clamp-2">
                  {post.data.description}
                </p>
              )}
              <div class="flex flex-wrap items-center gap-1.5 text-[11px] font-mono text-muted-foreground">
                <time>{meta.date}</time>
                <span class="text-muted-foreground/50">&middot;</span>
                <span>{meta.readTime}</span>
              </div>
            </div>
          </a>
        </li>
      );
    })}
  </ul>
)}
