const viewBox = '0 0 24 24';
const strokeAttrs = {
  fill: 'none',
  stroke: 'currentColor',
  'stroke-width': '2',
  'stroke-linecap': 'round',
  'stroke-linejoin': 'round',
} as const;
---

{isFill ? (
  <svg class={className} viewBox={viewBox} fill="currentColor" aria-hidden={title ? undefined : 'true'} role={title ? 'img' : undefined} set:html={(title ? `<title>${title}</title>` : '') + paths[name]} />
) : (
  <svg class={className} viewBox={viewBox} {...strokeAttrs} aria-hidden={title ? undefined : 'true'} role={title ? 'img' : undefined} set:html={(title ? `<title>${title}</title>` : '') + paths[name]} />
)}
