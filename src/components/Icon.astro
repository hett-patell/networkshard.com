---
/**
 * Inline SVG icon set. Replaces ~30 hand-inlined SVGs across the site.
 * Two families:
 *  - "fill" icons (brand glyphs) use fill="currentColor".
 *  - "stroke" icons (lucide-style) use fill="none" stroke="currentColor".
 * Pass a `class` to size/color (e.g. class="size-4 text-muted-foreground").
 */
interface Props {
  name: string;
  class?: string;
  title?: string;
}

const { name, class: className = 'size-4', title } = Astro.props;

const FILL = new Set(['github', 'linkedin', 'medium', 'x']);
const isFill = FILL.has(name);

const paths: Record<string, string> = {
