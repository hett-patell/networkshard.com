---
import Icon from './Icon.astro';
import { slugify } from '../lib/slugify';

interface Props {
  name: string;
  description: string;
  tech: string[];
  github?: string;
  href?: string;
  /** path label prefix shown above the title, e.g. "/projects/" or "/tools/" */
  pathPrefix: string;
}

const { name, description, tech, github, href, pathPrefix } = Astro.props;
const isExternal = href?.startsWith('http');
---

<div class="bento-card">
  <div class="mb-2">
    <span class="text-[10px] font-mono uppercase tracking-widest text-muted-foreground/60">
      {pathPrefix}{slugify(name)}
    </span>
    {href ? (
      <a
        href={href}
        target={isExternal ? "_blank" : undefined}
        rel={isExternal ? "noopener" : undefined}
        class="block mt-1 text-base font-semibold text-foreground hover:text-primary transition-colors"
      >
        {name}
      </a>
    ) : (
      <h3 class="text-base font-semibold text-foreground mt-1">{name}</h3>
    )}
  </div>
  <p class="text-sm text-muted-foreground leading-relaxed mb-3">{description}</p>
  <div class="flex flex-wrap items-center justify-between gap-3">
    {tech.length > 0 && (
      <div class="flex flex-wrap items-center gap-1.5">
        <span class="text-[10px] font-mono font-semibold uppercase tracking-wider text-muted-foreground/60 mr-1">
          Technologies:
        </span>
        {tech.map((t) => (
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-mono bg-muted/70 text-muted-foreground border border-border/60">
            {t}
          </span>
        ))}
      </div>
    )}
    <div class="flex items-center gap-3 shrink-0">
      {href && (
        <a
          href={href}
          target={isExternal ? "_blank" : undefined}
          rel={isExternal ? "noopener" : undefined}
          class="text-[11px] font-mono text-primary-hover hover:text-primary transition-colors"
          aria-label={`${name} details`}
        >
          {isExternal ? "live demo →" : "details →"}
        </a>
      )}
      {github && (
        <a
          href={github}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-1.5 text-muted-foreground hover:text-foreground transition-colors"
          aria-label={`${name} on GitHub`}
        >
          <Icon name="github" class="size-4" />
        </a>
      )}
    </div>
  </div>
</div>
