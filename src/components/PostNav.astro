---
import type { Post } from '../lib/posts';

interface Props {
  prev?: Post | null;
  next?: Post | null;
}

const { prev, next } = Astro.props;
---

{(prev || next) && (
  <nav class="mt-10 grid grid-cols-1 gap-3 sm:grid-cols-2" aria-label="Post navigation">
    {prev ? (
      <a href={`/blog/${prev.slug}`} class="bento-card group flex flex-col gap-1">
        <span class="text-[11px] font-mono uppercase tracking-wider text-muted-foreground">&larr; Previous</span>
        <span class="text-sm font-semibold text-foreground/90 group-hover:text-primary transition-colors line-clamp-2">{prev.data.title}</span>
      </a>
    ) : (
      <span aria-hidden="true"></span>
    )}
    {next ? (
      <a href={`/blog/${next.slug}`} class="bento-card group flex flex-col gap-1 sm:text-right sm:items-end">
        <span class="text-[11px] font-mono uppercase tracking-wider text-muted-foreground">Next &rarr;</span>
        <span class="text-sm font-semibold text-foreground/90 group-hover:text-primary transition-colors line-clamp-2">{next.data.title}</span>
      </a>
    ) : (
      <span aria-hidden="true"></span>
    )}
  </nav>
)}
