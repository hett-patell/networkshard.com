---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;

// Strip leading/trailing emoji, symbols, and stray punctuation so the TOC
// reads as clean text labels (post headings are peppered with emoji).
function clean(text: string): string {
  return text
    .replace(
      /[\u{1F000}-\u{1FAFF}\u{2600}-\u{27BF}\u{2190}-\u{21FF}\u{2B00}-\u{2BFF}\u{FE00}-\u{FE0F}\u{200D}\u{2122}\u{2139}\u{2328}\u{23CF}\u{23E9}-\u{23FA}\u{24C2}\u{25AA}-\u{25FE}]/gu,
      ''
    )
    .replace(/\s+/g, ' ')
    .replace(/^[\s:·•—–-]+|[\s:·•—–-]+$/g, '')
    .trim();
}

// Only h2/h3 make a useful contents list; show it only if there are enough.
const items = headings
  .filter((h) => h.depth === 2 || h.depth === 3)
  .map((h) => ({ ...h, label: clean(h.text) }))
  .filter((h) => h.label.length > 0);
const show = items.length >= 3;
---

{show && (
  <details class="toc group mb-8 rounded-lg border border-border/60 bg-muted/30" open>
    <summary class="toc-summary flex cursor-pointer list-none items-center gap-2 px-4 py-3 text-[11px] font-mono font-semibold uppercase tracking-widest text-muted-foreground select-none">
      <svg class="size-3.5 shrink-0 text-muted-foreground/70 transition-transform group-open:rotate-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      On this page
    </summary>
    <nav class="px-4 pb-4 pt-1" aria-label="Table of contents">
      <ul class="flex flex-col text-sm">
        {items.map((h) => (
          <li class:list={['toc-item', h.depth === 3 && 'toc-item--sub']}>
            <a href={`#${h.slug}`} class="toc-link">{h.label}</a>
          </li>
        ))}
      </ul>
    </nav>
  </details>
)}

<style>
  .toc-summary::-webkit-details-marker { display: none; }

  .toc-item {
    line-height: 1.4;
  }
  .toc-item--sub {
    margin-left: 0.875rem;
    border-left: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
  }

  .toc-link {
    display: block;
    padding: 0.3rem 0 0.3rem 0.75rem;
    margin-left: -0.75rem;
    border-radius: 4px;
    font-family: 'Geist Mono', ui-monospace, monospace;
    color: var(--muted-foreground);
    text-decoration: none;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .toc-item--sub .toc-link {
    padding-left: 0.75rem;
    margin-left: 0;
    color: color-mix(in srgb, var(--muted-foreground) 85%, transparent);
    font-size: 0.8125rem;
  }
  .toc-link:hover {
    color: var(--primary-text, var(--primary));
    background: color-mix(in srgb, var(--primary) 8%, transparent);
  }
</style>
