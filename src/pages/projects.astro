---
import BaseLayout from "../layouts/BaseLayout.astro";

type ProjectItem = {
    name: string;
    description: string;
    tech: string[];
    github?: string;
    href?: string;
};

const projects: ProjectItem[] = [
    {
        name: "ShardC2",
        description:
            "Policy-aware command-and-control framework for authorized red team operations. Go server/agent core with an operator dashboard, RBAC, audit logs, encrypted payloads, and built-in safety controls.",
        tech: ["Go", "PostgreSQL", "Redis", "WebSocket", "Docker"],
        github: "https://github.com/hett-patell/ShardC2",
    },
    {
        name: "ShardLure",
        description:
            "SSH honeypot that clusters bots by HASSH and username playbook instead of IP. Cowrie + journal ingest, intent classification, live globe dashboard, stealth persona with bait files, and STIX 2.1 IOC export.",
        tech: ["Go", "Python", "SQLite", "Cowrie", "HASSH", "STIX"],
        github: "https://github.com/hett-patell/ShardLure",
    },
    {
        name: "ShardFlow",
        description:
            "Layer-2 LAN workbench for authorized lab use. Discovers every device on the wire (ARP, mDNS, SSDP, OUI) and applies per-target drop, throttle, or silent pcap policies via nftables, tc/IFB, and AF_PACKET ARP poisoning. TUI + JSON-RPC CLI.",
        tech: ["Go", "Linux", "nftables", "libpcap", "AF_PACKET", "JSON-RPC"],
        github: "https://github.com/hett-patell/ShardFlow",
    },
    {
        name: "ShardPass",
        description:
            "Local-first Chrome MV3 TOTP authenticator with inline autofill, an encrypted local vault, QR / otpauth import, and per-domain account matching for 2FA-heavy workflows.",
        tech: ["TypeScript", "React", "Tailwind", "Vite", "Chrome MV3"],
        github: "https://github.com/hett-patell/ShardPass",
    },
    {
        name: "SSH Attack Telemetry",
        description:
            "Live globe visualising 30 days of SSH brute-force attempts against my exposed Oracle Cloud VM — 1,595 attempts, 64 unique IPs, 20+ countries, all bounced off pubkey-only auth.",
        tech: ["Astro", "Three.js", "globe.gl", "Python", "journalctl"],
        href: "/ssh-attacks/",
    },
    {
        name: "VulnInsights",
        description:
            "Vulnerability tracking dashboard for security assessments and penetration testing workflows, with status tracking, severity scoring, and finding-level notes.",
        tech: ["TypeScript", "JavaScript", "CSS"],
        github: "https://github.com/hett-patell/vulninsights",
    },
    {
        name: "Cinemax",
        description:
            "Full-stack movie booking and theatre management platform with a customer-facing frontend and an admin panel for shows, seats, and bookings.",
        tech: ["PHP", "JavaScript", "MySQL", "HTML", "CSS"],
        github: "https://github.com/hett-patell/cinemax",
    },
    {
        name: "QuickMeds",
        description:
            "Medicine lookup and pharmacy management app for fast inventory search, stock tracking, and over-the-counter prescription handling.",
        tech: ["JavaScript", "HTML", "CSS"],
        github: "https://github.com/hett-patell/QuickMeds",
    },
    {
        name: "Table No 21",
        description:
            "Restaurant point-of-sale system for streamlined order entry, billing, and live table tracking across dine-in and takeaway flows.",
        tech: ["PHP", "JavaScript", "MySQL", "HTML", "CSS"],
    },
];

const tools: ProjectItem[] = [
    {
        name: "ShardShell",
        description:
            "Refined PHP post-exploitation shell for authorized red team engagements, with separate Linux and Windows variants tuned to OS-native recon, priv-esc, and log-clearing. Ships with a Python build-time obfuscator and self-decrypting loader for AV evasion.",
        tech: ["PHP", "Python", "Linux", "Windows"],
        github: "https://github.com/hett-patell/ShardShell",
    },
    {
        name: "ShardPet",
        description:
            "Chromium MV3 extension that drops 1–3 animated Gen 5 Pokémon onto every page, with a per-hostname productivity nag that triggers a fullscreen “get back to work” overlay. Shadow-DOM isolated, GPU-only animation, offline after first sprite cache.",
        tech: ["TypeScript", "Vite", "Vitest", "Chrome MV3", "Shadow DOM"],
        github: "https://github.com/hett-patell/ShardPet",
    },
];
---

<BaseLayout
    title="Projects — Security Tools & Web Applications"
    description="Cybersecurity tools and web applications built by Het Patel — including vulnerability tracking dashboards and full-stack platforms."
>
    <!-- Projects -->
    <section class="pb-10 md:pb-12">
        <header class="mb-6">
            <h1
                class="text-3xl md:text-4xl font-bold tracking-tight text-foreground leading-tight mb-2"
            >
                Projects
            </h1>
            <p class="text-base text-muted-foreground">
                Things I've built and worked on.
            </p>
        </header>

        <div class="flex flex-col gap-3">
            {
                projects.map((project) => (
                    <div class="bento-card">
                        <div class="mb-2">
                            <span class="text-[10px] font-mono uppercase tracking-widest text-muted-foreground/60">
                                /projects/
                                {project.name
                                    .toLowerCase()
                                    .replace(/\s+/g, "-")}
                            </span>
                            <h3 class="text-base font-semibold text-foreground mt-1">
                                {project.name}
                            </h3>
                        </div>
                        <p class="text-sm text-muted-foreground leading-relaxed mb-3">
                            {project.description}
                        </p>
                        <div class="flex flex-wrap items-center justify-between gap-3">
                            {project.tech.length > 0 && (
                                <div class="flex flex-wrap items-center gap-1.5">
                                    <span class="text-[10px] font-mono font-semibold uppercase tracking-wider text-muted-foreground/60 mr-1">
                                        Technologies:
                                    </span>
                                    {project.tech.map((t) => (
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-mono bg-muted/70 text-muted-foreground border border-border/60">
                                            {t}
                                        </span>
                                    ))}
                                </div>
                            )}
                            <div class="flex items-center gap-3 shrink-0">
                                {project.href && (
                                    <a
                                        href={project.href}
                                        class="text-[11px] font-mono text-primary hover:text-primary-hover transition-colors"
                                        aria-label={`${project.name} live demo`}
                                    >
                                        live demo →
                                    </a>
                                )}
                                {project.github && (
                                    <a
                                        href={project.github}
                                        target="_blank"
                                        rel="noopener"
                                        class="text-muted-foreground hover:text-foreground transition-colors"
                                        aria-label={`${project.name} on GitHub`}
                                    >
                                        <svg
                                            class="size-4"
                                            viewBox="0 0 24 24"
                                            fill="currentColor"
                                        >
                                            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                                        </svg>
                                    </a>
                                )}
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>
    </section>

    <!-- Small Tools -->
    <section class="pb-10 md:pb-12">
        <header class="mb-6">
            <h2
                class="text-2xl md:text-3xl font-bold tracking-tight text-foreground leading-tight mb-2"
            >
                Small tools
            </h2>
            <p class="text-sm text-muted-foreground">
                Focused security utilities and experiments.
            </p>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            {
                tools.map((tool) => (
                    <div class="bento-card">
                        <div class="mb-2">
                            <span class="text-[10px] font-mono uppercase tracking-widest text-muted-foreground/60">
                                /tools/
                                {tool.name.toLowerCase().replace(/\s+/g, "-")}
                            </span>
                            <h3 class="text-base font-semibold text-foreground mt-1">
                                {tool.name}
                            </h3>
                        </div>
                        <p class="text-sm text-muted-foreground leading-relaxed mb-3">
                            {tool.description}
                        </p>
                        <div class="flex flex-wrap items-center justify-between gap-3">
                            {tool.tech.length > 0 && (
                                <div class="flex flex-wrap items-center gap-1.5">
                                    <span class="text-[10px] font-mono font-semibold uppercase tracking-wider text-muted-foreground/60 mr-1">
                                        Technologies:
                                    </span>
                                    {tool.tech.map((t) => (
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-mono bg-muted/70 text-muted-foreground border border-border/60">
                                            {t}
                                        </span>
                                    ))}
                                </div>
                            )}
                            {tool.github && (
                                <a
                                    href={tool.github}
                                    target="_blank"
                                    rel="noopener"
                                    class="inline-flex items-center gap-1.5 text-[11px] font-mono text-primary hover:text-primary-hover transition-colors"
                                    aria-label={`${tool.name} on GitHub`}
                                >
                                    GitHub
                                    <svg
                                        class="size-3.5"
                                        viewBox="0 0 24 24"
                                        fill="currentColor"
                                        aria-hidden="true"
                                    >
                                        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                                    </svg>
                                </a>
                            )}
                        </div>
                    </div>
                ))
            }
        </div>
    </section>
</BaseLayout>
