---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found" description="The page you're looking for doesn't exist.">
  <section class="flex flex-col items-center justify-center text-center py-20 min-h-[calc(100vh-16rem)]">
    <p class="font-mono text-xs font-semibold uppercase tracking-widest text-primary mb-4">Error 404</p>
    <h1 class="text-5xl md:text-7xl font-bold text-foreground tracking-tight mb-4">Page not found</h1>
    <p class="text-base text-muted-foreground max-w-md mb-8">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <div class="flex flex-col sm:flex-row items-center gap-3">
      <a href="/" class="btn-neo-primary">Go home</a>
      <a href="/blog" class="btn-neo-outline">Read the blog</a>
    </div>
  </section>
</BaseLayout>
