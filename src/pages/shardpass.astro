---
import ShardProjectLayout from "../layouts/ShardProjectLayout.astro";
import { getShardProject } from "../lib/shard-projects";

const project = getShardProject("shardpass")!;
---

<ShardProjectLayout project={project}>
  <!-- ShardPass-specific: security architecture -->
  <section class="pb-10 md:pb-14">
    <h2 class="text-[10px] font-mono uppercase tracking-widest text-muted-foreground/60 mb-4">
      Security Architecture
    </h2>
    <div class="grid gap-3 sm:grid-cols-2">
      {[
        { label: "Vault Encryption", value: "AES-256-GCM" },
        { label: "Key Derivation", value: "PBKDF2-HMAC-SHA256, 250k rounds" },
        { label: "TOTP Standard", value: "RFC 6238 (time-based)" },
        { label: "HOTP Standard", value: "RFC 4226 (counter-based)" },
        { label: "Optional Sync", value: "E2EE via SRP + libsodium" },
        { label: "Data Location", value: "Local-only (chrome.storage)" },
      ].map((item) => (
        <div class="bento-card p-4">
          <div class="text-[10px] font-mono uppercase tracking-widest text-muted-foreground/60">{item.label}</div>
          <div class="mt-1.5 font-mono text-sm text-foreground">{item.value}</div>
        </div>
      ))}
    </div>
  </section>
</ShardProjectLayout>
