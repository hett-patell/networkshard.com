---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedPosts } from '../../lib/posts';
import { slugify } from '../../lib/slugify';
import PostList from '../../components/PostList.astro';

type CatPost = { data: { category?: string; tags?: string[] } };
const categoryOf = (post: CatPost) =>
  post.data.category || post.data.tags?.[0] || 'General';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const categorySet = new Set<string>();
  for (const post of posts) {
    categorySet.add(slugify(post.data.category || post.data.tags?.[0] || 'General'));
  }
  return [...categorySet].map((category) => ({ params: { category } }));
}

const { category } = Astro.params;

const posts = (await getPublishedPosts()).filter(
  (post) => slugify(categoryOf(post)) === category
);

const titleLabel = posts[0]
  ? categoryOf(posts[0])
  : (category || 'category').replace(/-/g, ' ');
---

<BaseLayout title={`Category: ${titleLabel}`} description={`Posts in ${titleLabel}.`}>
  <section class="pb-8 md:pb-12">
    <header class="mb-6">
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-foreground leading-tight">{titleLabel}</h1>
      <p class="mt-2 text-sm font-mono text-muted-foreground uppercase tracking-wider">{posts.length} Posts</p>
    </header>

    <PostList posts={posts} variant="detailed" />
  </section>
</BaseLayout>
