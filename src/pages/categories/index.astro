---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedPosts } from '../../lib/posts';
import { slugify } from '../../lib/slugify';

const posts = await getPublishedPosts();

const categoryMap = new Map<string, { name: string; count: number }>();

for (const post of posts) {
  const fallbackCategory = post.data.tags?.[0];
  const categoryName = post.data.category || fallbackCategory || 'General';
  const slug = slugify(categoryName);
  const current = categoryMap.get(slug);
  if (current) {
    current.count += 1;
  } else {
    categoryMap.set(slug, { name: categoryName, count: 1 });
  }
}

const categories = [...categoryMap.entries()]
  .map(([slug, value]) => ({ slug, ...value }))
  .sort((a, b) => b.count - a.count || a.name.localeCompare(b.name));
---

<BaseLayout title="Categories" description="Browse posts by category.">
  <section class="pb-8 md:pb-12">
    <header class="mb-6">
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-foreground leading-tight">Categories</h1>
      <p class="mt-2 text-sm font-mono text-muted-foreground uppercase tracking-wider">{categories.length} Categories</p>
    </header>

    <ul class="projects-table" role="list">
      {categories.map((category) => (
        <li>
          <a href={`/categories/${category.slug}/`} class="projects-row">
            <div class="projects-row__title">
              <span class="projects-row__path">/categories/{category.slug}</span>
              <h2 class="projects-row__headline text-lg font-semibold leading-snug text-foreground/90">{category.name}</h2>
            </div>
            <p class="projects-row__desc text-sm leading-relaxed text-muted-foreground">
              Browse all posts filed under {category.name}.
            </p>
            <div class="projects-row__meta">
              <span class="projects-row__label">Posts</span>
              <div class="projects-row__tags">
                <span class="projects-row__tag">{category.count}</span>
              </div>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

