---
import ShardProjectLayout from "../layouts/ShardProjectLayout.astro";
import { getShardProject } from "../lib/shard-projects";

const project = getShardProject("shardtune")!;
---

<ShardProjectLayout project={project}>
  <!-- ShardTune-specific: mock popup preview -->
  <section class="pb-10 md:pb-14">
    <h2 class="text-[10px] font-mono uppercase tracking-widest text-muted-foreground/60 mb-4">
      Preview
    </h2>
    <div class="bento-card overflow-hidden p-0">
      <div class="flex items-center gap-1.5 border-b border-border bg-muted/40 px-4 py-2.5">
        <span class="h-2.5 w-2.5 rounded-full bg-muted-foreground/40"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-muted-foreground/40"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-muted-foreground/40"></span>
        <span class="ml-3 font-mono text-[11px] text-muted-foreground">shardtune — popup</span>
      </div>
      <div class="p-5 font-mono text-[13px] leading-relaxed">
        <div class="text-muted-foreground">Now Playing</div>
        <div class="mt-2 text-foreground">
          <span class="text-primary">Blinding Lights</span> — The Weeknd
        </div>
        <div class="mt-1 text-xs text-muted-foreground">After Hours · 3:20</div>
        <div class="mt-3 flex items-end gap-0.5">
          {[6, 10, 14, 9, 16, 12, 18, 11, 14, 8, 13, 17, 10, 7, 12, 15, 9, 11].map((h) => (
            <span class="w-1 rounded-sm bg-primary/80" style={`height:${h * 2}px`}></span>
          ))}
        </div>
        <div class="mt-4 grid grid-cols-2 gap-3 text-xs">
          <div class="rounded border border-border p-2">
            <div class="text-muted-foreground">Peak hour</div>
            <div class="mt-1 text-foreground">11pm – 1am</div>
          </div>
          <div class="rounded border border-border p-2">
            <div class="text-muted-foreground">Vibe Sync</div>
            <div class="mt-1 text-primary">82% match</div>
          </div>
        </div>
        <div class="mt-4 flex items-center gap-2 text-muted-foreground text-xs">
          <span class="inline-block h-2 w-2 rounded-full bg-primary animate-pulse"></span>
          local-only · BYO Client ID
        </div>
      </div>
    </div>
  </section>
</ShardProjectLayout>
