---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedPosts } from '../../lib/posts';
import PostList from '../../components/PostList.astro';

const posts = await getPublishedPosts();

const pinned = posts.find(p => p.data.pinned);
const regularPosts = posts.filter(p => !p.data.pinned);
---

<BaseLayout title="Blog — Cybersecurity & Penetration Testing Articles" description="Articles on cybersecurity, penetration testing, vulnerability assessment, ethical hacking, and security research by Het Patel." image={`${Astro.site}og/blog.png`}>

  <!-- Pinned Post -->
  {pinned && (
    <section class="mb-10" aria-label="Pinned article">
      <a href={`/blog/${pinned.slug}`} class="pinned-changelog block group">
        <div class="flex items-center gap-2 mb-3.5">
          <span class="pinned-changelog-dot"></span>
          <span class="font-mono text-[11px] font-semibold uppercase tracking-widest text-primary">Pinned</span>
          <span class="flex-1 h-px bg-border/70"></span>
        </div>
        <h2 class="blog-card-title font-mono text-base font-semibold leading-snug text-foreground/90 motion-safe:transition-colors motion-safe:duration-150 group-hover:text-primary">{pinned.data.title}</h2>
        {pinned.data.description && pinned.data.description.trim().toLowerCase() !== pinned.data.title.trim().toLowerCase() && (
          <p class="mt-1.5 font-mono text-sm leading-relaxed text-muted-foreground line-clamp-2">{pinned.data.description}</p>
        )}
      </a>
    </section>
  )}

  <!-- Blog Posts by Year -->
  <section aria-label="Latest articles">
    <div class="min-h-[calc(100vh-18rem)]">
      <PostList posts={regularPosts} variant="compact" groupByYear />
    </div>
  </section>

{posts.length === 0 && (
    <div class="bento-card text-center py-12">
      <p class="text-muted-foreground">No posts yet. Check back soon!</p>
    </div>
  )}
</BaseLayout>
