---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getPublishedPosts } from '../../../lib/posts';
import { slugify } from '../../../lib/slugify';
import PostList from '../../../components/PostList.astro';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const slugs = new Set<string>();
  for (const post of posts) {
    for (const tag of post.data.tags || []) slugs.add(slugify(tag));
  }
  return [...slugs].map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params;

const allPosts = await getPublishedPosts();
const posts = allPosts.filter((post) =>
  (post.data.tags || []).some((t) => slugify(t) === tag)
);

// Display the original (raw) tag spelling that maps to this slug.
const label =
  posts.flatMap((p) => p.data.tags || []).find((t) => slugify(t) === tag) ||
  (tag || 'tag').replace(/-/g, ' ');
---

<BaseLayout title={`${label} — Blog`} description={`Articles tagged "${label}" — cybersecurity, penetration testing, and security research.`}>
  <section class="pb-10 md:pb-12">
    <header class="mb-6">
      <a href="/blog/tags" class="text-xs font-mono text-muted-foreground hover:text-foreground transition-colors">&larr; All tags</a>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-foreground leading-tight mt-3 mb-2">
        <span class="text-primary">#</span>{label}
      </h1>
      <p class="text-base text-muted-foreground">{posts.length} {posts.length === 1 ? 'article' : 'articles'}</p>
    </header>

    <PostList posts={posts} variant="detailed" />
  </section>
</BaseLayout>
