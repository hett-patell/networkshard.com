---
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { getPublishedPosts } from '../lib/posts';
import { personSchema, websiteSchema } from '../lib/jsonld';
import { computeReadTime } from '../lib/readTime';

const posts = await getPublishedPosts();
const latestPost = posts[0] || null;
const latestReadTime = latestPost ? computeReadTime(latestPost.body, latestPost.data.readTime) : '';
const ogImage = `${Astro.site}og/home.png`;
const latestPostDescription = latestPost?.data.description?.trim() || '';
const shouldShowLatestDescription =
  !!latestPost &&
  latestPostDescription.length > 0 &&
  latestPostDescription.toLowerCase() !== latestPost.data.title.trim().toLowerCase();
---

<BaseLayout
  title="Het Patel — Cybersecurity Engineer"
  description="Het Patel — Cybersecurity Engineer specializing in penetration testing, VAPT, vulnerability assessment, red teaming, and security research."
  image={ogImage}
  jsonLd={[personSchema(), websiteSchema()]}
>
  <section class="hero-section relative py-0" id="hero">
    <div class="bento-grid grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3">

      <!-- Row 1: Unified hero (photo + identity) -->
      <div class="bento-card bento-hero sm:col-span-2 md:col-span-3 !p-0 overflow-hidden">
        <div class="flex flex-col sm:flex-row">
          <!-- Photo side -->
          <div class="bento-hero__photo relative w-full sm:w-[220px] md:w-[260px] shrink-0 bg-muted/30 overflow-hidden" aria-hidden="true">
            <div class="aspect-[2/3] sm:aspect-auto sm:h-full w-full relative">
              <img
                src="/photo.webp"
                alt="Het Patel — Cybersecurity Engineer"
                width="832"
                height="832"
                class="absolute inset-0 w-full h-full object-contain photo-light"
                loading="eager"
                fetchpriority="high"
                decoding="async"
              />
              <img
                src="/photo-dark.webp"
                alt="Het Patel — Cybersecurity Engineer"
                width="832"
                height="832"
                class="absolute inset-0 w-full h-full object-contain photo-dark"
                loading="eager"
                fetchpriority="low"
                decoding="async"
              />
            </div>
          </div>

          <!-- Identity side -->
          <div class="bento-hero__identity flex-1 p-5 md:p-8 flex flex-col justify-center relative overflow-hidden">
            <div class="bento-hero__identity-content">
              <!-- Role -->
              <p class="identity-role flex items-center gap-2 font-mono text-xs text-muted-foreground mb-4">
                <span class="identity-role__dot inline-block w-2 h-2 rounded-full bg-primary shrink-0" style="box-shadow: 0 0 0 3px color-mix(in srgb, var(--primary) 20%, transparent)" aria-hidden="true"></span>
                Cybersecurity Engineer — Intern<span class="text-muted-foreground/40">/</span>Inventyv
              </p>

              <!-- Title -->
              <h1 class="identity-title font-black tracking-tighter uppercase leading-none text-3xl md:text-[2.75rem] lg:text-5xl">
                <span class="identity-title__line">Trust nothing.</span><br/>
                <span class="identity-title__line text-primary">Test everything.</span>
              </h1>

              <!-- Bio -->
              <div class="identity-bio mt-4 text-[0.875rem] md:text-[0.9375rem] text-muted-foreground max-w-md leading-relaxed space-y-1">
                <p>
                  I'm Het — <span class="text-foreground/90 font-medium">Cybersecurity Engineer</span> &
                  <span class="text-foreground/90 font-medium">VAPT specialist</span>.
                  Penetration testing, vulnerability assessment, and
                  <span class="text-foreground/90 font-medium">security research</span>.
                </p>
              </div>

              <!-- CTA -->
              <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3 sm:gap-4 mt-6">
                <a href="/blog" class="btn-neo-primary min-h-[44px] sm:min-h-0 w-full sm:w-auto text-center">Read the blog</a>
                <a href="/about" class="btn-neo-outline min-h-[44px] sm:min-h-0 w-full sm:w-auto text-center">About me</a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Row 2: Latest Post (spans 2 cols) -->
      <div class="bento-card sm:col-span-2 md:col-span-2">
        {latestPost ? (
          <a href={`/blog/${latestPost.slug}`} class="block group">
            <span class="text-xs font-mono font-semibold uppercase tracking-wider text-muted-foreground">Latest post</span>
            <p class="mt-3 text-lg font-semibold text-foreground group-hover:text-primary transition-colors">{latestPost.data.title}</p>
            {shouldShowLatestDescription && (
              <p class="mt-1 text-sm text-muted-foreground leading-relaxed line-clamp-2">{latestPostDescription}</p>
            )}
            <div class="mt-3 flex items-center gap-1.5 text-[11px] font-mono text-muted-foreground">
              <time>{latestPost.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
              {latestReadTime && <><span aria-hidden="true">&middot;</span><span>{latestReadTime}</span></>}
            </div>
          </a>
        ) : (
          <div>
            <span class="text-xs font-mono font-semibold uppercase tracking-wider text-muted-foreground">Latest post</span>
            <p class="mt-3 text-sm text-muted-foreground">Coming soon...</p>
          </div>
        )}
        <div class="mt-4 pt-3 border-t border-border">
          <a href="/blog" class="text-xs font-mono text-muted-foreground hover:text-primary transition-colors">
            View all posts &rarr;
          </a>
        </div>
      </div>

      <!-- Connect Card -->
      <div class="bento-card bento-connect">
        <div class="flex h-full flex-col gap-5">
          <div class="flex items-center justify-between">
            <span class="text-[11px] font-mono font-semibold uppercase tracking-wider text-muted-foreground">Contact</span>
          </div>
          <div class="h-px w-full bg-border/60" aria-hidden="true"></div>

          <p class="identity-title text-[2rem] leading-[0.95] text-foreground">
            <span>Let's</span><br />
            <span>connect.</span>
          </p>

          <SocialLinks />
        </div>
      </div>

      <!-- Row 3: Small info cards -->
      <!-- Hall of Fame Card -->
      <div class="bento-card">
        <span class="text-xs font-mono font-semibold uppercase tracking-wider text-muted-foreground">Hall of Fame</span>
        <p class="mt-2 text-lg font-bold text-foreground">CERT-IN</p>
        <p class="text-sm text-muted-foreground">September & October 2025</p>
      </div>

      <!-- Certification Card -->
      <div class="bento-card">
        <span class="text-xs font-mono font-semibold uppercase tracking-wider text-muted-foreground">Certification</span>
        <p class="mt-2 text-lg font-bold text-foreground">CRTA</p>
        <p class="text-sm text-muted-foreground">Certified Red Team Analyst</p>
      </div>

      <!-- TryHackMe Card -->
      <a href="https://tryhackme.com/p/hettt" target="_blank" rel="noopener" class="bento-card group block">
        <span class="text-xs font-mono font-semibold uppercase tracking-wider text-muted-foreground">TryHackMe</span>
        <p class="mt-2 text-lg font-bold text-foreground">Top 8%</p>
        <p class="text-sm text-muted-foreground group-hover:text-primary transition-colors">@hettt</p>
      </a>

    </div>
  </section>
</BaseLayout>

<style>
  /* Light/dark photo switching — matches merox.dev pattern */
  .photo-light { display: block; }
  .photo-dark { display: none; }
  :global([data-theme="dark"]) .photo-light { display: none; }
  :global([data-theme="dark"]) .photo-dark { display: block; }
</style>

<script is:inline>
  // Handle photo load error - show fallback
  document.addEventListener('DOMContentLoaded', () => {
    const img = document.querySelector('.bento-hero__photo img');
    if (img) {
      img.addEventListener('error', () => {
        img.style.display = 'none';
      });
    }
  });
</script>
