---
import BaseLayout from "./BaseLayout.astro";
import type { ShardProject } from "../lib/shard-projects";

interface Props {
  project: ShardProject;
}

const { project } = Astro.props;
const midpoint = Math.ceil(project.features.length / 2);
const featuresLeft = project.features.slice(0, midpoint);
const featuresRight = project.features.slice(midpoint);
---

<BaseLayout
  title={`${project.name} — ${project.tagline}`}
  description={project.description}
  image={`${Astro.site}og/projects.png`}
>
  <!-- Hero -->
  <section class="pb-10 md:pb-14">
    <header class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[11px] font-mono bg-muted/70 text-primary border border-border/60">
          <span class={`h-1.5 w-1.5 rounded-full ${project.status === "Live" ? "bg-primary" : "bg-muted-foreground"}`}></span>
          {project.status}
        </span>
        <a
          href="/projects"
          class="text-[11px] font-mono text-muted-foreground hover:text-foreground transition-colors"
        >
          ← all projects
        </a>
      </div>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-foreground leading-tight">
        {project.name}
      </h1>
      <p class="mt-2 text-lg text-muted-foreground">
        {project.tagline}
      </p>
    </header>

    <!-- Actions -->
    <div class="flex flex-wrap items-center gap-3 mb-10">
      <a
        href={project.github}
        target="_blank"
        rel="noopener"
        class="btn-neo-primary"
      >
        <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        View on GitHub
      </a>
      {project.demo && (
        <a
          href={project.demo}
          target="_blank"
          rel="noopener"
          class="btn-neo-outline"
        >
          Live Demo →
        </a>
      )}
    </div>

    <!-- Description -->
    <div class="bento-card p-6 md:p-8">
      <h2 class="text-[10px] font-mono uppercase tracking-widest text-muted-foreground/60 mb-3">
        About
      </h2>
      <p class="text-sm leading-relaxed text-muted-foreground">
        {project.description}
      </p>
    </div>
  </section>

  <!-- Features -->
  <section class="pb-10 md:pb-14">
    <h2 class="text-[10px] font-mono uppercase tracking-widest text-muted-foreground/60 mb-4">
      Features
    </h2>
    <div class="grid gap-3 md:grid-cols-2">
      <div class="flex flex-col gap-3">
        {featuresLeft.map((f) => (
          <div class="bento-card p-4">
            <div class="flex items-start gap-3">
              <span class="mt-0.5 h-4 w-4 shrink-0 text-primary">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span class="text-sm text-foreground/90">{f}</span>
            </div>
          </div>
        ))}
      </div>
      <div class="flex flex-col gap-3">
        {featuresRight.map((f) => (
          <div class="bento-card p-4">
            <div class="flex items-start gap-3">
              <span class="mt-0.5 h-4 w-4 shrink-0 text-primary">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span class="text-sm text-foreground/90">{f}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="pb-10 md:pb-14">
    <h2 class="text-[10px] font-mono uppercase tracking-widest text-muted-foreground/60 mb-4">
      Tech Stack
    </h2>
    <div class="flex flex-wrap gap-2">
      {project.tech.map((t) => (
        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[11px] font-mono bg-muted/70 text-muted-foreground border border-border/60">
          <span class="h-1.5 w-1.5 rounded-full bg-current opacity-40"></span>
          {t}
        </span>
      ))}
    </div>
  </section>

  <!-- Slot for project-specific content -->
  <slot />

  <!-- Footer nav -->
  <section class="pb-10 md:pb-14">
    <div class="flex flex-wrap items-center justify-between gap-4 border-t border-border/40 pt-6">
      <a
        href="/projects"
        class="text-sm font-mono text-muted-foreground hover:text-foreground transition-colors"
      >
        ← All projects
      </a>
      <a
        href={project.github}
        target="_blank"
        rel="noopener"
        class="text-sm font-mono text-primary hover:text-foreground transition-colors"
      >
        {project.name} on GitHub →
      </a>
    </div>
  </section>
</BaseLayout>
